# polymarket-weather-trade Environment Variables
# Copy this file to .env and set all required values.
# This file documents every variable consumed by src/config.js.

# Polygon private key used to sign wallet and CLOB requests.
# Accepts either 0x-prefixed or raw hex key format.
POLYGON_PRIVATE_KEY=your_polygon_private_key_here

# Signature profile used by Polymarket CLOB authentication.
# 0 = EOA wallet, 1 = POLY_PROXY, 2 = GNOSIS_SAFE/proxy-style account.
SIGNATURE_TYPE=2

# Funder/proxy wallet address that actually holds collateral for trading.
# If omitted, runtime may warn and fall back to the signer address.
FUNDER_ADDRESS=0xYourPolymarketProxyAddress

# Explicit Polymarket API key used for authenticated CLOB operations.
# Leave blank only if you expect runtime derivation from wallet signature.
POLY_API_KEY=

# Explicit Polymarket API secret paired with POLY_API_KEY.
# Leave blank only if you expect runtime derivation from wallet signature.
POLY_API_SECRET=

# Explicit Polymarket API passphrase paired with POLY_API_KEY.
# Leave blank only if you expect runtime derivation from wallet signature.
POLY_PASSPHRASE=

# Token required for privileged ops routes (settings writes, trigger routes, mode changes).
# Keep non-empty in any shared or production environment.
OPS_API_TOKEN=

# Controls whether read-only status/health endpoints are public.
# true = public status/health pages, false = require ops token for those endpoints too.
PUBLIC_READ_ENDPOINTS_ENABLED=true

# Enables WebSocket-driven near-real-time monitoring loops.
# Set to false to rely on slower scheduled status checks only.
REALTIME_MONITORING=true

# Public market WebSocket endpoint (price/orderbook style updates).
MARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# Authenticated user WebSocket endpoint (orders/trades/account updates).
USER_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/user

# OpenAI API key used by the decision engine.
OPENAI_API_KEY=sk-your-openai-key

# OpenAI model identifier used for weather decision analysis.
OPENAI_MODEL=gpt-5-nano

# OpenWeatherMap API key used for 5-day/3-hour forecast ingestion.
OWM_API_KEY=your_openweathermap_api_key

# NOAA CDO token used for historical climate observations.
NOAA_CDO_TOKEN=your_noaa_cdo_token

# Start offset in days for "recent" NOAA sampling window.
# Example: 1 means first recent day sampled is D-1.
NOAA_RECENT_DAYS_START=1

# Number of recent daily NOAA samples to include.
# Example: 2 means D-1 and D-2 when START=1.
NOAA_RECENT_DAYS_COUNT=2

# Number of prior years to sample on the same event date.
# Example: 5 means one sample per year across the last 5 years.
NOAA_SAME_DAY_YEARS_BACK_COUNT=5

# Telegram bot token from BotFather for alerts and command support.
TELEGRAM_BOT_TOKEN=

# Telegram chat id that receives bot notifications and command responses.
TELEGRAM_CHAT_ID=

# HTTP server port for API endpoints and status/settings pages.
PORT=3001

# Logging verbosity level (error, warn, info, debug).
LOG_LEVEL=info

# Cron schedule for full weather market scans (UTC, 5-field expression).
# Default runs every 2 hours.
SCAN_CRON=0 */2 * * *

# Cron schedule for daily summary report/notification (UTC, 5-field expression).
DAILY_REPORT_CRON=50 23 * * *

# Cron schedule for stale unfilled order cancellation checks (UTC, 5-field expression).
STALE_ORDER_CANCEL_CRON=* * * * *

# Cron schedule for fallback bet-status checks when realtime WS is quiet (UTC, 5-field expression).
STATUS_FALLBACK_CRON=*/10 * * * *

# USD notional target per entry attempt.
# Polymarket practical minimum is typically 1 USD.
BET_AMOUNT_USD=1

# Legacy/override sizing key consumed by config.betSize path.
# Keep aligned with BET_AMOUNT_USD unless intentionally diverging.
BET_SIZE=1

# Maximum number of concurrently active tracked weather positions.
MAX_ACTIVE_BETS=8

# Maximum number of events analyzed per scan cycle after prefiltering.
MAX_EVENTS_PER_SCAN=30

# Ignore events resolving sooner than this many hours from now.
SCAN_WINDOW_MIN_HOURS=12

# Ignore events resolving later than this many hours from now.
SCAN_WINDOW_MAX_HOURS=48

# Maximum number of new bets allowed per UTC day.
MAX_DAILY_BETS=12

# Maximum number of unique daily exposure keys (event_id + token_id).
# Counts active positions, open BUY orders, and in-flight entry intents.
MAX_DAILY_UNIQUE_EXPOSURES=12

# Daily cap on total OpenAI tokens used by analysis requests.
MAX_DAILY_TOKENS=500000

# Enables PR-A dual-pass validator for borderline candidates.
AI_VALIDATOR_ENABLED=true

# Upper confidence threshold defining borderline zone for second-pass validation.
AI_VALIDATOR_CONFIDENCE_MAX=74

# Upper edge threshold defining borderline zone for second-pass validation.
AI_VALIDATOR_EDGE_MAX=0.06

# No-trade half-band width (in temperature degrees) around integer bucket boundaries.
# Trades inside this uncertainty band are rejected unless override thresholds are met.
BOUNDARY_NO_TRADE_BAND_DEG=0.35

# Confidence override threshold required to bypass boundary no-trade rejection.
BOUNDARY_OVERRIDE_CONFIDENCE=82

# Edge override threshold required to bypass boundary no-trade rejection.
BOUNDARY_OVERRIDE_EDGE=0.08

# Primary runtime execution mode selector.
# off = no submissions, shadow = analyze only, paper = simulated, live = real orders.
TRADING_MODE=paper

# Balance warning threshold that triggers low-balance alerts.
MIN_BALANCE_WARN_USD=20

# Hard balance floor under which new entries are blocked.
MIN_BALANCE_STOP_USD=3

# Minimum acceptable entry share price (0-1 probability scale).
MIN_ODDS_VALUE=0.05

# Maximum acceptable entry share price (0-1 probability scale).
MAX_ODDS_VALUE=0.70

# Baseline minimum AI confidence required to permit an entry.
# Can be raised dynamically by volatility controls.
MIN_CONFIDENCE=60

# Minimum edge requirement (estimated probability minus implied market probability).
MIN_EDGE=0.03

# Enables dynamic confidence floor adjustments based on recent odds volatility.
VOLATILITY_CONFIDENCE_ENABLED=true

# Low-volatility threshold (percent move metric) that triggers first confidence bump.
VOLATILITY_LOW_PCT=8

# High-volatility threshold (percent move metric) that triggers stronger confidence bump.
VOLATILITY_HIGH_PCT=18

# Additional confidence points required when volatility exceeds VOLATILITY_LOW_PCT.
VOLATILITY_CONFIDENCE_BUMP_LOW=3

# Additional confidence points required when volatility exceeds VOLATILITY_HIGH_PCT.
VOLATILITY_CONFIDENCE_BUMP_HIGH=7

# Minimum liquidity quality score required before placing an order.
# Score combines spread, top-of-book depth, and quote freshness.
LIQUIDITY_MIN_SCORE=55

# Maximum quote age (milliseconds) considered fresh for liquidity scoring.
LIQUIDITY_FRESH_MS=90000

# Spread cap used in liquidity score normalization (decimal, 0.08 = 8%).
LIQUIDITY_MAX_SPREAD_PCT=0.08

# Absolute maximum single-bet notional permitted by risk checks.
MAX_BET_SIZE=2

# Minimum post-close wait (minutes) before auto-settlement to won/lost is allowed.
# Helps avoid premature settlement during optimistic challenge/dispute windows.
RESOLUTION_GRACE_MINUTES=120

# Consecutive per-scope execution failures required to open the circuit breaker.
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3

# Cooldown duration (ms) before open circuit breaker can probe half-open state.
CIRCUIT_BREAKER_COOLDOWN_MS=300000

# Staleness threshold (ms) for expected fills before incident escalation.
EXPECTED_FILL_STALE_MS=180000

# Absolute share-size mismatch tolerance for reconciliation checks.
RECONCILIATION_TOLERANCE_SIZE=0.25

# Relative price mismatch tolerance for reconciliation checks (0.15 = 15%).
RECONCILIATION_TOLERANCE_PRICE_PCT=0.15

# Minimum interval (ms) between expensive exchange refreshes in reconciliation loop.
EXCHANGE_REFRESH_MIN_INTERVAL_MS=12000

# Grace period (minutes) before locally placed orders missing on exchange are auto-cancelled.
STALE_PLACED_GRACE_MINUTES=15

# Take-profit percentage for very low-cost entries near $0.01.
# Interpreted as percent units (200 means +200%).
LOW_BET_TAKE_PROFIT=200

# Take-profit percentage for expensive entries near $0.99.
# Interpreted as percent units (5 means +5%).
HIGH_BET_TAKE_PROFIT=5

# Take-profit lockout is dynamic and data-driven (entry price, unrealized gain, time-to-end).
# No static env knob is required; stop-loss checks remain active near event end.

# Preferred stop-loss percentage key (decimal format, 0.25 = 25% drawdown stop).
STOP_LOSS_TCP=0.25
