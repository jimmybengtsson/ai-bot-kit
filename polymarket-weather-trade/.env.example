# ─── polymarket-weather-trade — Environment Variables ──────────────────────
# Copy this file to .env and fill in your values.
# This file contains ALL variables currently read by src/config.js.

# ─── Polygon / Polymarket Authentication ───────────────────────────────────
# Private key used to sign CLOB/API requests.
# Accepts with or without 0x prefix.
POLYGON_PRIVATE_KEY=your_polygon_private_key_here

# Signature type used by the Polymarket CLOB client:
# 0 = EOA wallet, 1 = POLY_PROXY, 2 = GNOSIS_SAFE/proxy style account.
SIGNATURE_TYPE=2

# Funder/proxy wallet address holding your Polymarket funds.
# If empty, app warns and may fall back to signer address.
FUNDER_ADDRESS=0xYourPolymarketProxyAddress

# Optional pre-generated API creds (from `npm run setup`).
# If missing, bot attempts derivation from wallet signature.
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=

# ─── Realtime WebSocket Monitoring ──────────────────────────────────────────
# Enable/disable realtime exit checks from WS updates.
# Any value except literal "false" is treated as enabled.
REALTIME_MONITORING=true

# Public market channel WS endpoint (price/order-book style updates).
MARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# Authenticated user channel WS endpoint (order/trade/account updates).
USER_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/user

# ─── Model / Data Providers ────────────────────────────────────────────────
# OpenAI key for AI decision engine.
OPENAI_API_KEY=sk-your-openai-key

# OpenAI model id used for analysis.
OPENAI_MODEL=gpt-5-nano

# OpenWeatherMap API key (required).
# Used for 5-day/3-hour forecast pulls per event.
OWM_API_KEY=your_openweathermap_api_key

# NOAA CDO API token (required).
# Used for historical climate/observation context.
NOAA_CDO_TOKEN=your_noaa_cdo_token

# ─── Telegram Notifications (Optional) ─────────────────────────────────────
# Bot token from @BotFather.
TELEGRAM_BOT_TOKEN=

# Chat id to receive notifications and command responses.
TELEGRAM_CHAT_ID=

# ─── Server / Logging ───────────────────────────────────────────────────────
# HTTP server port for REST + status page.
PORT=3001

# Winston log level: error | warn | info | debug.
LOG_LEVEL=info

# ─── Position Sizing / Runtime Gates ───────────────────────────────────────
# USD amount per bet submission (Polymarket minimum is 1).
BET_AMOUNT_USD=1

# Legacy/override size key. If set, this value is preferred by config.betSize.
# Keep equal to BET_AMOUNT_USD unless you explicitly need separate behavior.
BET_SIZE=1

# Maximum concurrently active weather positions.
MAX_ACTIVE_BETS=8

# Daily cap on number of new bets placed.
MAX_DAILY_BETS=12

# Daily token usage cap for AI requests.
MAX_DAILY_TOKENS=500000

# Paper mode toggle.
# true  = simulate orders only
# false = place live orders
PAPER_TRADE=true

# Alert threshold: warn when balance drops below this value.
MIN_BALANCE_WARN_USD=20

# Hard stop threshold: block new bets below this value.
MIN_BALANCE_STOP_USD=3

# ─── Price / Decision Risk Filters ─────────────────────────────────────────
# Minimum allowed entry share price (0-1 scale).
MIN_ODDS_VALUE=0.05

# Maximum allowed entry share price (0-1 scale).
MAX_ODDS_VALUE=0.70

# Minimum AI confidence required to place a bet (0-100 scale).
MIN_CONFIDENCE=60

# Minimum edge required to place a bet (probability delta, 0-1 scale).
MIN_EDGE=0.03

# Maximum single bet size in USD risk checks.
MAX_BET_SIZE=2

# ─── Exit Controls (Take-Profit / Stop-Loss) ───────────────────────────────
# Dynamic take-profit endpoints (percent units, not decimals):
# LOW_BET_TAKE_PROFIT applies near $0.01 entries.
# HIGH_BET_TAKE_PROFIT applies near $0.99 entries.
LOW_BET_TAKE_PROFIT=200
HIGH_BET_TAKE_PROFIT=5

# Signed lockout offset for take-profit checks relative to event end:
#   positive N  -> TP lockout starts N minutes BEFORE event end.
#   negative N  -> TP lockout starts |N| minutes AFTER event end.
# Examples:
#   120   => pause TP 120 minutes before end, and keep TP paused after end.
#   -180  => keep TP active through end, then pause TP starting 180 minutes after end.
#   999999  => effectively pause TP for the whole bet (lockout starts before entry time).
#   -999999 => effectively keep TP active for the whole bet (lockout starts far after closure).
# Stop-loss checks still run during any TP lockout window.
TAKE_PROFIT_DISABLE_BEFORE_END_MINUTES=0

# Preferred stop-loss env key in this codebase.
# Decimal format: 0.25 means sell when price falls ~25% from entry.
STOP_LOSS_TCP=0.25
