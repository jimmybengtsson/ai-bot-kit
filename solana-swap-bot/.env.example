# solana-swap-bot environment configuration
# Copy to .env and adjust for production.

# ── Solana / Helius ──
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
HELIUS_API_KEY=YOUR_HELIUS_KEY
WALLET_PATH=/absolute/path/to/your/wallet-keypair.json

# ── Jupiter ──
JUPITER_API_KEY=YOUR_JUPITER_KEY
JUPITER_PRICE_API=https://api.jup.ag/price/v3
JUPITER_QUOTE_API=https://api.jup.ag/swap/v1/quote
JUPITER_SWAP_API=https://api.jup.ag/swap/v1/swap

# ── OpenAI ──
OPENAI_API_KEY=sk-YOUR_OPENAI_KEY
OPENAI_MODEL=gpt-5-nano
OPENAI_MODEL_TRADING=gpt-5-nano
OPENAI_MODEL_TRADING_ANALYSIS=gpt-5-nano
OPENAI_MODEL_VALIDATOR=gpt-5-nano
OPENAI_MODEL_DAILY_REPORT=gpt-5-nano

# ── Runtime / Server ──
PAPER_TRADE=true
LOG_LEVEL=info
PORT=3000

# Required to enable /trigger/* endpoints.
# Send as either:
# - x-admin-key: <key>
# - Authorization: Bearer <key>
SERVER_ADMIN_API_KEY=

# Shared timeout for outbound HTTP requests (ms)
HTTP_TIMEOUT_MS=15000

# External scraper service for Twitter/X fetching
# Example: http://localhost:3030
# If empty, tweet scanning is disabled.
SCRAPER_SERVER_ADDRESS=

# Optional API key for scraper server auth (cloak-scraper API_PASSWORD).
# When set, requests include both:
# - x-api-key: <key>
# - Authorization: Bearer <key>
SCRAPER_SERVER_API_KEY=

# ── Cron Schedules (UTC) ──
# Use standard 5-field cron syntax: minute hour day-of-month month day-of-week
CRON_TRADING_LOOP=10 * * * *
CRON_PORTFOLIO_SNAPSHOT=*/15 * * * *
CRON_MEMORY_FLUSH=0 */2 * * *
CRON_DAILY_REPORT=53 23 * * *
CRON_STALE_POSITION_CHECK=*/30 * * * *

# ── Strategy Allocation ──
# Main control for strategy split. Guardian share is automatically (100 - this value).
# Default: 60 => degen 60%, guardian 40%.
# Set 0 => degen disabled, guardian 100%.
# Set 100 => guardian disabled, degen 100%.
RISK_DEGEN_SHARE_PCT=60

# Optional: set guardian share directly instead.
# Used only when RISK_DEGEN_SHARE_PCT is unset.
# Example: 55 => degen becomes 45 automatically.
RISK_GUARDIAN_SHARE_PCT=

# ── Risk Parameters ──
RISK_DAILY_LOSS_LIMIT_PCT=5
RISK_DAILY_TARGET_PCT=10
RISK_COOLDOWN_AFTER_LOSSES=3
RISK_DEGEN_MAX_PCT=25
RISK_GUARDIAN_MAX_PCT=15
# Optional absolute per-trade caps in SOL (0 = disabled).
# Effective hard cap per strategy is: min(share*pct cap, max-sol cap when set).
RISK_DEGEN_MAX_SOL=0
RISK_GUARDIAN_MAX_SOL=0
RISK_MAX_HELD_TOKENS=8
# AI/schema/runtime trade-count ceiling per tick (default 2 = one trade per strategy bias)
RISK_MAX_TRADES_PER_TICK=2

# ── Arbitrage Parameters ──
ARB_SLIPPAGE_BPS=30
ARB_GAS_FEE_SOL=0.000005
ARB_MIN_SPREAD_PCT_2LEG=2
ARB_MIN_SPREAD_PCT_3LEG=3
ARB_LIMIT_TIMEOUT_MS=180000
ARB_LIMIT_RETRY_MS=5000
ARB_AUTO_MIN_SPREAD_PCT=5

# ── SOL Reserve ──
# Keep only a small SOL buffer for transaction fees.
SOL_RESERVE=0.05

# Main trading/take-profit reserve in USDC.
USDC_RESERVE=10

# ── Optional Universe Overrides ──
# Leave empty to use built-in defaults from config.js.

# JSON object: {"SYM":"MINT", ...}
WATCHED_TOKENS_JSON=

# JSON object: {"MINT":decimals, ...}
TOKEN_DECIMALS_JSON=

# Comma-separated DEX names
COMPARE_DEXES_CSV=

# Comma-separated keyword list
SOLANA_KEYWORDS_CSV=

