# cloak-scraper environment configuration
#
# HOW TO USE THIS FILE (non-dev friendly):
# 1. Copy this file to .env
#    macOS/Linux command: cp .env.example .env
# 2. Open .env in a text editor.
# 3. Change values only on the right side of '='.
# 4. Save .env, then start the server with: npm start
#
# Value formats:
# - true/false for switches
# - numbers for time/count values
# - plain text for passwords, hostnames, proxy URLs

# =========================
# SERVER BASICS
# =========================

# Runtime mode:
# - development: more verbose logs, local testing
# - production: real deployment mode
NODE_ENV=development

# Network host binding:
# - 0.0.0.0 = accessible from other machines on your network/VPS
# - 127.0.0.1 = only accessible from this same machine
HOST=0.0.0.0

# Server port number.
# Example: if PORT=3030 then URL is http://localhost:3030
PORT=3030

# Log every request in terminal (true/false)
LOG_REQUESTS=true

# Max total time (in ms) the HTTP server allows a request before timing out.
# 90000 ms = 90 seconds.
REQUEST_TIMEOUT_MS=90000

# Max time (in ms) browser navigation/actions wait before failing.
NAVIGATION_TIMEOUT_MS=35000

# =========================
# REQUEST QUEUE (OVERLOAD PROTECTION)
# =========================

# Enable/disable built-in queue when many requests arrive at once.
# true = safer under load, false = every request runs immediately.
QUEUE_ENABLED=true

# How many scrape requests are allowed to run at the same time.
# Lower value = safer memory/CPU usage.
QUEUE_CONCURRENCY=2

# Maximum number of waiting requests in queue.
# If queue is full, new requests are rejected with HTTP 429.
QUEUE_MAX_SIZE=100

# =========================
# SECURITY
# =========================

# API password used by client servers.
# - Leave empty: open mode (no auth required)
# - Set value: clients must send x-api-key OR Authorization: Bearer <key>
# Use a strong random value in production.
API_PASSWORD=

# =========================
# SCRAPING LIMITS
# =========================

# Default number of items returned when request does not include ?results=
DEFAULT_RESULTS=10

# Hard cap for ?results= to avoid very heavy scraping requests.
MAX_RESULTS=50

# How many scroll cycles to attempt on scroll-based pages (like X) before stopping.
MAX_SCROLLS=8

# Wait time (ms) between scroll actions.
# Increase this on slow websites to allow content to load.
SCROLL_DELAY_MS=1300

# =========================
# CLOAKBROWSER OPTIONS
# =========================

# true = run browser in hidden/headless mode
# false = visible browser window (helpful for debugging)
CLOAK_HEADLESS=true

# Human-like input behavior (mouse/keyboard/scroll simulation)
CLOAK_HUMANIZE=true

# Humanization profile:
# - default: balanced speed
# - careful: slower, more deliberate actions
CLOAK_HUMAN_PRESET=default

# Optional proxy URL for outgoing browser traffic.
# Example: http://user:pass@proxy-host:8080
CLOAK_PROXY=

# Browser locale/language presented to websites.
CLOAK_LOCALE=en-US

# Browser timezone, e.g. Europe/Paris or America/New_York
CLOAK_TIMEZONE=

# If true and proxy is set, CloakBrowser can infer locale/timezone from proxy IP.
CLOAK_GEOIP=false

# Extra Chromium args (comma-separated, no spaces).
# Advanced option - leave empty unless you know what you need.
# Example: --fingerprint=12345,--disable-http2
CLOAK_ARGS=

# =========================
# ADVANCED CLOAKBROWSER ENV VARS (OPTIONAL)
# =========================
# Keep these commented unless you need special behavior.

# Use your own local Chromium binary instead of auto-downloaded one.
# CLOAKBROWSER_BINARY_PATH=

# Where CloakBrowser stores downloaded browser binaries.
# CLOAKBROWSER_CACHE_DIR=

# Custom download source URL for CloakBrowser binary updates.
# CLOAKBROWSER_DOWNLOAD_URL=

# true = automatic update checks, false = disable update checks
# CLOAKBROWSER_AUTO_UPDATE=true

# true = skip binary checksum verification (not recommended)
# CLOAKBROWSER_SKIP_CHECKSUM=false
