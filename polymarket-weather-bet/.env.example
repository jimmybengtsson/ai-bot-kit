# polymarket-weather-bet environment variables

# EOA private key used to sign Polymarket CLOB requests and, if needed, derive API credentials.
# Accepts either raw hex or 0x-prefixed hex. Keep this secret.
POLYGON_PRIVATE_KEY=your_polygon_private_key_here

# Signature version used by the Polymarket CLOB client. Keep default unless your account setup requires otherwise.
SIGNATURE_TYPE=2

# Polymarket proxy/funder address used for account balance/position context and order funding.
# If left empty, wallet address from POLYGON_PRIVATE_KEY is used as fallback.
FUNDER_ADDRESS=0xYourPolymarketProxyAddress

# Optional explicit Polymarket API key. If omitted (with secret/passphrase), the app tries createOrDeriveApiKey().
POLY_API_KEY=

# Optional explicit Polymarket API secret paired with POLY_API_KEY.
POLY_API_SECRET=

# Optional explicit Polymarket API passphrase paired with POLY_API_KEY.
POLY_PASSPHRASE=

# OpenAI API key used for temperature outcome selection and validation calls.
OPENAI_API_KEY=sk-your-openai-key

# OpenAI model name passed to responses.create (must support structured JSON output).
OPENAI_MODEL=gpt-5-nano

# OpenWeatherMap API key for forecast retrieval by event location.
OWM_API_KEY=your_openweathermap_api_key

# NOAA CDO API token used for historical station-based TMAX climate context.
NOAA_CDO_TOKEN=your_noaa_cdo_token

# NOAA recent sample configuration:
# default (when unset): D-2, D-3, D-4
NOAA_RECENT_DAYS_START=2
NOAA_RECENT_DAYS_COUNT=3

# NOAA same-date yearly sample configuration:
# default (when unset): last 5 years
NOAA_SAME_DAY_YEARS_BACK_COUNT=5

# HTTP port for Express server endpoints (/ , /health , /trigger/run).
PORT=3010

# Winston logging level (for example: error, warn, info, debug).
LOG_LEVEL=info

# When true, orders are simulated and no live trade is posted; keep true until fully validated.
PAPER_TRADE=true

# Maximum number of event slots the bot may hold per daily run window.
DAILY_BET_SLOTS=5

# UTC cron expression for scheduled run. Default means every day at 16:00 UTC.
DAILY_SCAN_CRON=0 16 * * *

# Minimum hours from now before an event can qualify for scanning.
SCAN_WINDOW_MIN_HOURS=12

# Maximum hours from now for event eligibility; must be greater than SCAN_WINDOW_MIN_HOURS.
SCAN_WINDOW_MAX_HOURS=36

# Skip event if YES ask price is above this value (range should stay within 0 to 1).
YES_PRICE_MAX=0.30

# Skip event/order if YES ask price is below this value.
# Together with YES_PRICE_MAX, this defines the allowed ask-price band.
YES_PRICE_MIN=0.05

# Fixed share size used for each BUY YES order (or simulated order in paper mode).
FIXED_SHARES=5

# Expiration time for posted limit orders in minutes.
# Orders are submitted as GTD and expire after this duration.
ORDER_EXPIRY_MINUTES=60
